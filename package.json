{
  "name": "asistencia",
  "version": "2.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "start": "pnpm --filter server start",
    "lint": "pnpm -r lint",
    "build:client": "pnpm --filter asistencia-client build",
    "build": "pnpm run build:client"
  }
}